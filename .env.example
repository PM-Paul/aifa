ANTHROPIC_API_KEY=your-key-here

# Free GCP API key — needed for Cloud Billing Catalog API (public pricing, no billing required)
# Get one at: console.cloud.google.com → APIs & Services → Credentials → Create API Key
# Enable: Cloud Billing API
GCP_API_KEY=your-gcp-key-here

# IAM user/role credentials with only the pricing:GetProducts permission — used for
# live AWS instance pricing via the Price List Query API. Falls back to a pinned
# price table if unset or if the API call fails.
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key

# Upstash Redis REST credentials — used to rate-limit /api/analyze to 10 assessments
# per IP per day. Provision a Redis database via the Vercel Marketplace integration
# under Storage; Vercel auto-populates KV_REST_API_URL/KV_REST_API_TOKEN when linked
# to this project, which the @upstash/redis client reads here.
KV_REST_API_URL=your-kv-rest-api-url
KV_REST_API_TOKEN=your-kv-rest-api-token

# Google service account key (JSON) — used to append assessment + feedback rows to the
# AIFA Assessment Log Google Sheet. Create a service account in Google Cloud Console,
# enable the Google Sheets API, generate a JSON key, and share the spreadsheet with the
# service account's client_email as an Editor. Paste the ENTIRE service account JSON here
# as a single-line string (wrap the value in single quotes so the embedded double quotes
# and \n newlines in private_key survive).
GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com",...}'

# Developer bypass token — a request to /api/analyze whose X-AIFA-Dev header matches this
# value skips the rate limit entirely (for testing/demos). Leave unset in normal use; the
# bypass is disabled whenever this is empty.
AIFA_DEV_TOKEN=your-dev-bypass-token
